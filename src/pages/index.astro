---
import Base from '../layouts/Base.astro';
import { getCollection } from 'astro:content';

const allArticles = await getCollection('articles', ({ data }) => !data.draft);

const sorted = allArticles.sort((a, b) => {
  const aArea = Array.isArray(a.data.area) ? a.data.area[0] : a.data.area;
  const bArea = Array.isArray(b.data.area) ? b.data.area[0] : b.data.area;
  if (aArea !== bArea) return aArea.localeCompare(bArea);
  if (a.data.order !== b.data.order) return (a.data.order ?? 99) - (b.data.order ?? 99);
  return a.data.title.localeCompare(b.data.title);
});

// Ordine fisso: News, Generali, Adulti – Club, Scuola Nuoto Bambini
const AREA_ORDER = ['News', 'Generali', 'Adulti – Club', 'Scuola Nuoto Bambini'];
const allAreas: string[] = [];
sorted.forEach(a => {
  const arr = Array.isArray(a.data.area) ? a.data.area : [a.data.area];
  arr.forEach(ar => { if (!allAreas.includes(ar)) allAreas.push(ar); });
});
allAreas.sort((a, b) => {
  const ia = AREA_ORDER.indexOf(a);
  const ib = AREA_ORDER.indexOf(b);
  if (ia !== -1 && ib !== -1) return ia - ib;
  if (ia !== -1) return -1;
  if (ib !== -1) return 1;
  return a.localeCompare(b);
});

const areaCount: Record<string, number> = {};
allAreas.forEach(ar => {
  areaCount[ar] = sorted.filter(a => {
    const arr = Array.isArray(a.data.area) ? a.data.area : [a.data.area];
    return arr.includes(ar);
  }).length;
});

// Raggruppa per area includendo tutti gli articoli che hanno quell'area (non solo primaria)
const grouped: Record<string, typeof sorted> = {};
allAreas.forEach(ar => {
  grouped[ar] = sorted.filter(a => {
    const arr = Array.isArray(a.data.area) ? a.data.area : [a.data.area];
    return arr.includes(ar);
  });
});
---

<Base title="Help Desk" description="Procedure e FAQ Athlon su abbonamenti, corsi, portale/app, prenotazioni e regole del club.">
  <div class="page-wrap">

    <nav class="sidebar">
      <div class="sidebar-label">Categorie</div>
      <a href="/" class="sidebar-link active">
        Tutti <span class="sidebar-count">{sorted.length}</span>
      </a>
      <div class="sidebar-divider"></div>
      {allAreas.map(ar => (
        <a href={`#area-${ar.toLowerCase().replace(/\s+/g,'-').replace(/[^a-z0-9-]/g,'')}`} class="sidebar-link">
          {ar} <span class="sidebar-count">{areaCount[ar]}</span>
        </a>
      ))}
    </nav>

    <main class="main-content">

      <div class="home-hero">
        <div class="hero-eyebrow">Help Center</div>
        <h1 class="hero-title">GUIDE &amp; <span>SUPPORTO</span></h1>
        <p class="hero-sub">Procedure e FAQ su abbonamenti, corsi, portale/app, prenotazioni e regole del club.</p>
        <div class="hero-stats">
          <div><div class="stat-num">{sorted.length}</div><div class="stat-lbl">Articoli</div></div>
          <div><div class="stat-num">{allAreas.length}</div><div class="stat-lbl">Aree</div></div>
        </div>
      </div>

      <div class="search-bar-sticky">
        <div class="search-bar-inner">
          <input type="text" id="wiki-search" placeholder="Digita qui per cercare…" autocomplete="off" />
          <button class="search-bar-btn" type="button">Ricerca</button>
        </div>
      </div>

      <div class="area-menu">
        <a href="#top" class="area-pill active" data-area="all">
          Tutti <span class="area-pill-count">({sorted.length})</span>
        </a>
        {allAreas.map(ar => (
          <a
            href={`#area-${ar.toLowerCase().replace(/\s+/g,'-').replace(/[^a-z0-9-]/g,'')}`}
            class={`area-pill${ar === 'News' ? ' area-pill-news' : ''}`}
            data-area={ar}
          >
            {ar} <span class="area-pill-count">({areaCount[ar]})</span>
          </a>
        ))}
      </div>

      <div id="search-results" style="display:none; padding: 24px 56px;">
        <div id="search-header" class="section-header" style="margin-bottom:16px"></div>
        <div id="search-grid" class="articles-grid"></div>
      </div>

      <div id="articles-sections">
        {allAreas.map(area => (
          <section
            class="section-wrap"
            id={`area-${area.toLowerCase().replace(/\s+/g,'-').replace(/[^a-z0-9-]/g,'')}`}
            data-area={area}
          >
            <div class={`section-header${area === 'News' ? ' section-header-news' : ''}`}>
              <span class="section-title">{area === 'News' ? '🔔 ' + area : area}</span>
              <span class="section-count">{grouped[area].length}</span>
            </div>
            <div class="articles-grid">
              {grouped[area].map(article => {
                const areas = Array.isArray(article.data.area) ? article.data.area : [article.data.area];
                return (
                  <a href={`/wikiathlon/${article.slug}/`} class="article-card">
                    <div class="card-area-tag">{areas.join(' · ')}</div>
                    <div class="card-title">{article.data.title}</div>
                    <div class="card-summary">{article.data.description}</div>
                    <div class="card-footer">
                      <div class="card-tags">
                        {(article.data.tags ?? []).slice(0, 3).map((t: string) => (
                          <span class="card-tag">{t}</span>
                        ))}
                      </div>
                      <span class="card-arrow">→</span>
                    </div>
                  </a>
                );
              })}
            </div>
          </section>
        ))}
      </div>

    </main>
  </div>
</Base>

<script>
const searchInput = document.getElementById('wiki-search') as HTMLInputElement;
const searchResults = document.getElementById('search-results')!;
const searchHeader = document.getElementById('search-header')!;
const searchGrid = document.getElementById('search-grid')!;
const articlesSections = document.getElementById('articles-sections')!;

interface ArticleData { title: string; description: string; area: string; href: string; tags: string; }

function extractArticles(): ArticleData[] {
  const seen = new Set<string>();
  const cards = document.querySelectorAll('.article-card');
  const result: ArticleData[] = [];
  cards.forEach(card => {
    const href = (card as HTMLAnchorElement).href;
    if (!seen.has(href)) {
      seen.add(href);
      result.push({
        title: card.querySelector('.card-title')?.textContent || '',
        description: card.querySelector('.card-summary')?.textContent || '',
        area: card.querySelector('.card-area-tag')?.textContent || '',
        href,
        tags: Array.from(card.querySelectorAll('.card-tag')).map(t => t.textContent).join(' ')
      });
    }
  });
  return result;
}

function cardHTML(a: ArticleData, q: string): string {
  const hl = (text: string) => text.replace(
    new RegExp(`(${q.replace(/[.*+?^${}()|[\]\\]/g, '\\$&')})`, 'gi'),
    '<mark style="background:#FFE066;color:#000;padding:0 2px">$1</mark>'
  );
  return `<a href="${a.href}" class="article-card">
    <div class="card-area-tag">${a.area}</div>
    <div class="card-title">${hl(a.title)}</div>
    <div class="card-summary">${hl(a.description)}</div>
    <div class="card-footer"><div class="card-tags"></div><span class="card-arrow">→</span></div>
  </a>`;
}

let articles: ArticleData[] = [];

function runSearch(q: string) {
  searchInput.value = q;
  if (!q) {
    searchResults.style.display = 'none';
    articlesSections.style.display = 'block';
    return;
  }
  if (!articles.length) articles = extractArticles();
  const ql = q.toLowerCase();
  const results = articles.filter(a =>
    a.title.toLowerCase().includes(ql) ||
    a.description.toLowerCase().includes(ql) ||
    a.tags.toLowerCase().includes(ql) ||
    a.area.toLowerCase().includes(ql)
  );
  articlesSections.style.display = 'none';
  searchResults.style.display = 'block';
  if (!results.length) {
    searchGrid.innerHTML = '<div class="empty-state"><div class="empty-icon">∅</div><div class="empty-msg">Nessun risultato per <strong>' + q + '</strong></div></div>';
    searchHeader.innerHTML = '';
  } else {
    searchHeader.innerHTML = `<span class="section-title">${results.length} risultat${results.length === 1 ? 'o' : 'i'}</span> <span class="section-count">per "${q}"</span>`;
    searchGrid.innerHTML = results.map(a => cardHTML(a, ql)).join('');
  }
}

searchInput.addEventListener('input', () => runSearch(searchInput.value.trim()));

const urlQ = new URLSearchParams(window.location.search).get('q');
if (urlQ) setTimeout(() => runSearch(urlQ), 50);

document.querySelectorAll('.area-pill').forEach(pill => {
  pill.addEventListener('click', () => {
    document.querySelectorAll('.area-pill').forEach(p => p.classList.remove('active'));
    pill.classList.add('active');
  });
});
</script>
