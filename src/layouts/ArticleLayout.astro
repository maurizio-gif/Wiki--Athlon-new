---
import Base from './Base.astro';
import { getCollection } from 'astro:content';

interface Props {
  title: string;
  description: string;
  area: string | string[];
  tags?: string[];
  slug: string;
}

const { title, description, area, tags = [], slug } = Astro.props;

// Normalizza area come array
const areas = Array.isArray(area) ? area : [area];

// Prendi tutti gli articoli per sidebar e navigazione
const allArticles = await getCollection('articles');
const sorted = allArticles.sort((a, b) => {
  const aArea = Array.isArray(a.data.area) ? a.data.area[0] : a.data.area;
  const bArea = Array.isArray(b.data.area) ? b.data.area[0] : b.data.area;
  return aArea.localeCompare(bArea) || a.data.title.localeCompare(b.data.title);
});

// Aree uniche per sidebar — ordine fisso
const AREA_ORDER = ['News', 'Generali', 'Adulti – Club', 'Scuola Nuoto Bambini'];
const allAreas: string[] = [];
allArticles.forEach(a => {
  const arr = Array.isArray(a.data.area) ? a.data.area : [a.data.area];
  arr.forEach(ar => { if (!allAreas.includes(ar)) allAreas.push(ar); });
});
allAreas.sort((a, b) => {
  const ia = AREA_ORDER.indexOf(a);
  const ib = AREA_ORDER.indexOf(b);
  if (ia !== -1 && ib !== -1) return ia - ib;
  if (ia !== -1) return -1;
  if (ib !== -1) return 1;
  return a.localeCompare(b);
});

// Conteggio per area
const areaCount: Record<string, number> = {};
allAreas.forEach(ar => {
  areaCount[ar] = allArticles.filter(a => {
    const arr = Array.isArray(a.data.area) ? a.data.area : [a.data.area];
    return arr.includes(ar);
  }).length;
});

// Prev / Next nella stessa area primaria
const primaryArea = areas[0];
const sameAreaArticles = sorted.filter(a => {
  const arr = Array.isArray(a.data.area) ? a.data.area : [a.data.area];
  return arr[0] === primaryArea;
});
const currentIdx = sameAreaArticles.findIndex(a => a.slug === slug);
const prevArticle = sameAreaArticles[currentIdx - 1];
const nextArticle = sameAreaArticles[currentIdx + 1];

const currentURL = `https://wiki.athlonroma.it/wikiathlon/${slug}/`;
---

<Base title={title} description={description}>
  <div class="page-wrap">
    <nav class="sidebar">
      <div class="sidebar-label">Categorie</div>
      <a href="/" class="sidebar-link">
        Tutti <span class="sidebar-count">{allArticles.length}</span>
      </a>
      <div class="sidebar-divider"></div>
      {allAreas.map(ar => (
        <a
          href={`/?area=${encodeURIComponent(ar)}`}
          class={`sidebar-link ${areas.includes(ar) ? 'active' : ''}`}
        >
          {ar} <span class="sidebar-count">{areaCount[ar]}</span>
        </a>
      ))}
    </nav>

    <main class="main-content">

      <!-- SEARCH BAR STICKY — sempre visibile -->
      <div class="search-bar-sticky">
        <div class="search-bar-inner">
          <input
            type="text"
            id="article-search"
            placeholder="Digita qui per cercare…"
            autocomplete="off"
          />
          <button class="search-bar-btn" id="search-go-btn">Ricerca</button>
        </div>
      </div>

      <div class="article-wrap">

        <nav class="article-breadcrumb">
          <a href="/">Guide</a>
          <span class="breadcrumb-sep">/</span>
          <a href={`/?area=${encodeURIComponent(primaryArea)}`}>{primaryArea}</a>
          <span class="breadcrumb-sep">/</span>
          <span>{title}</span>
        </nav>

        <div>
          {areas.map(ar => (
            <a href={`/?area=${encodeURIComponent(ar)}`} class="article-area-badge">{ar}</a>
          ))}
        </div>

        <h1 class="article-title">{title}</h1>
        <code class="article-url-display">{currentURL}</code>

        <div class="article-summary-block">
          <p>{description}</p>
        </div>

        <div class="article-body">
          <slot />
        </div>

        {tags.length > 0 && (
          <div class="article-tags-section">
            <span class="tags-label">Tag:</span>
            {tags.map(t => <span class="card-tag">{t}</span>)}
          </div>
        )}

        <nav class="article-nav">
          {prevArticle ? (
            <a href={`/wikiathlon/${prevArticle.slug}/`} class="article-nav-btn">
              <span class="nav-label">← Precedente</span>
              <span class="nav-title">{prevArticle.data.title}</span>
            </a>
          ) : <div></div>}
          {nextArticle ? (
            <a href={`/wikiathlon/${nextArticle.slug}/`} class="article-nav-btn right">
              <span class="nav-label">Successivo →</span>
              <span class="nav-title">{nextArticle.data.title}</span>
            </a>
          ) : <div></div>}
        </nav>

      </div>
    </main>
  </div>
</Base>

<script>
  const input = document.getElementById('article-search') as HTMLInputElement;
  const btn = document.getElementById('search-go-btn') as HTMLButtonElement;

  function doSearch() {
    const q = input.value.trim();
    if (q) {
      window.location.href = `/?q=${encodeURIComponent(q)}`;
    } else {
      window.location.href = '/';
    }
  }

  btn.addEventListener('click', doSearch);
  input.addEventListener('keydown', (e) => {
    if (e.key === 'Enter') doSearch();
  });

  // Apri tutti i link esterni in nuova tab
  document.querySelectorAll('.article-body a').forEach(link => {
    const href = (link as HTMLAnchorElement).href;
    if (href && !href.startsWith(window.location.origin) && !href.startsWith('/') && !href.startsWith('#')) {
      link.setAttribute('target', '_blank');
      link.setAttribute('rel', 'noopener noreferrer');
    }
  });

  // Wrappa tutte le tabelle in un div scrollabile
  document.querySelectorAll('.article-body table').forEach(table => {
    const wrapper = document.createElement('div');
    wrapper.style.cssText = 'overflow-x:auto;-webkit-overflow-scrolling:touch;margin:24px 0;';
    table.parentNode?.insertBefore(wrapper, table);
    wrapper.appendChild(table);
    (table as HTMLElement).style.margin = '0';
  });
</script>
