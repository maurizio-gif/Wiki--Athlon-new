---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const { title = 'Athlon Wiki', description = 'Procedure e FAQ Athlon su abbonamenti, corsi, portale/app, prenotazioni e regole del club.' } = Astro.props;
---
<!DOCTYPE html>
<html lang="it">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content={description} />
  <title>{title} – Athlon Wiki</title>
  <link rel="icon" type="image/png" href="/favicon.png" />
  <script>
    (function() {
      const hash = window.location.hash;
      if (hash && (hash.includes('invite_token=') || hash.includes('recovery_token=') || hash.includes('confirmation_token='))) {
        window.location.href = '/admin/' + hash;
      }
    })();
  </script>
</head>
<body>

  <header class="site-header">
    <a href="/" class="header-logo">
      <img src="/logo.png" alt="Athlon Club" />
      <span class="logo-text">ATHLON <span>WIKI</span></span>
    </a>
    <div class="header-divider"></div>
    <div class="header-spacer"></div>
    <button
      class="btn-chat"
      onclick="if(window.ready2chat){window.ready2chat.open()}else{window.open('https://zgcrbhl8m6b.typeform.com/WikiAthlon?utm_source=wiki&utm_medium=chat&utm_campaign=chat','_blank')}"
    >
      💬 Chatta con noi
    </button>
    <a
      href="https://zgcrbhl8m6b.typeform.com/WikiAthlon?utm_source=wiki&utm_medium=header&utm_campaign=assistenza"
      target="_blank"
      rel="noopener"
      class="btn-assistenza"
    >
      Richiedi Assistenza
    </a>
  </header>

  <!-- EVENTI BAR -->
  <a href="https://www.athlonroma.it/events/" target="_blank" rel="noopener" class="events-bar">
    <span class="events-bar-label">🎉 EVENTI</span>
    <span class="events-bar-text">Scopri tutti gli eventi in programma ad Athlon Club</span>
    <span class="events-bar-cta">Vedi gli eventi →</span>
  </a>

  <slot />

  <footer class="site-footer">
    <div class="footer-top">
      <div class="footer-info">
        <strong>Point 2000 Srl – Società Sportiva Dilettantistica</strong><br/>
        Via Ugo Ojetti 134, 00137 Roma &nbsp;|&nbsp;
        P.IVA IT05154811003<br/>
        Affiliazione ASI: LAZ-RM4453 &nbsp;|&nbsp; FIN: 996434 &nbsp;|&nbsp; CSEN: 71519
      </div>
      <a
        href="https://zgcrbhl8m6b.typeform.com/WikiAthlon?utm_source=wiki&utm_medium=footer&utm_campaign=assistenza"
        target="_blank"
        rel="noopener"
        class="btn-assistenza-footer"
      >
        💬 Richiedi Assistenza
      </a>
    </div>
    <div class="footer-links">
      <a href="https://www.athlonroma.it" target="_blank">← Torna al sito principale</a>
      &nbsp;|&nbsp;
      <a href="https://www.athlonroma.it/regolamento" target="_blank">Termini e Condizioni</a>
      &nbsp;|&nbsp;
      <a href="https://www.athlonroma.it/privacy/" target="_blank">Privacy Policy</a>
    </div>
  </footer>

  <!-- Floating assistenza button -->
  <a
    href="https://zgcrbhl8m6b.typeform.com/WikiAthlon?utm_source=wiki&utm_medium=floating&utm_campaign=assistenza"
    target="_blank"
    rel="noopener"
    class="floating-chat-btn"
    aria-label="Richiedi Assistenza"
  >
    <span class="floating-chat-icon">💬</span>
    <span class="floating-chat-label">RICHIEDI ASSISTENZA</span>
  </a>

  <!-- Ready2Chat bot -->
  <script is:inline>
    (function() {
      var s = document.createElement('script');
      s.defer = true;
      s.id = '__carrierLoader__';
      s.src = 'https://ready2chat.tm.arch01.xyz/carrier/loader.js?t=2026-04-22T08:56:12.530+00:00';
      s.setAttribute('data-bot-identifier', 'athlon-helpbot-690c80264fdcdf44c1d999bf');
      document.body.appendChild(s);
    })();
  </script>

</body>
</html>
