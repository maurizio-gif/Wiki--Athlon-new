---
import '../styles/global.css';
import { ViewTransitions } from 'astro:transitions';

interface Props {
  title?: string;
  description?: string;
}

const { title = 'Athlon Wiki', description = 'Procedure e FAQ Athlon su abbonamenti, corsi, portale/app, prenotazioni e regole del club.' } = Astro.props;
---
<!DOCTYPE html>
<html lang="it">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content={description} />
  <title>{title} – Athlon Wiki</title>
  <link rel="icon" type="image/png" href="/favicon.png" />
  <ViewTransitions />
  <!-- Open Graph / Social sharing -->
  <meta property="og:type" content="website" />
  <meta property="og:title" content={`${title} – Athlon Wiki`} />
  <meta property="og:description" content={description} />
  <meta property="og:image" content="https://athlon-wiki.netlify.app/og-image.jpg" />
  <meta property="og:image:width" content="1200" />
  <meta property="og:image:height" content="630" />
  <meta property="og:site_name" content="Athlon Club 4.0 – Help Desk" />
  <!-- Twitter / WhatsApp -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:image" content="https://athlon-wiki.netlify.app/og-image.jpg" />
  <script>
    (function() {
      const hash = window.location.hash;
      if (hash && (hash.includes('invite_token=') || hash.includes('recovery_token=') || hash.includes('confirmation_token='))) {
        window.location.href = '/admin/' + hash;
      }
    })();
  </script>
</head>
<body>

  <header class="site-header">
    <a href="/" class="header-logo">
      <img src="/logo.png" alt="Athlon Club" />
      <span class="logo-text">ATHLON <span>WIKI</span></span>
    </a>
    <div class="header-divider"></div>
    <div class="header-spacer"></div>
    <a
      href="https://zgcrbhl8m6b.typeform.com/WikiAthlon?utm_source=wiki&utm_medium=header&utm_campaign=assistenza"
      target="_blank"
      rel="noopener"
      class="btn-assistenza"
    >
      Richiedi Assistenza
    </a>
  </header>

  <slot />

  <footer class="site-footer">
    <div class="footer-top">
      <div class="footer-info">
        <strong>Point 2000 Srl – Società Sportiva Dilettantistica</strong><br/>
        Via Ugo Ojetti 134, 00137 Roma &nbsp;|&nbsp;
        P.IVA IT05154811003<br/>
        Affiliazione ASI: LAZ-RM4453 &nbsp;|&nbsp; FIN: 996434 &nbsp;|&nbsp; CSEN: 71519
      </div>
      <a
        href="https://zgcrbhl8m6b.typeform.com/WikiAthlon?utm_source=wiki&utm_medium=footer&utm_campaign=assistenza"
        target="_blank"
        rel="noopener"
        class="btn-assistenza-footer"
      >
        💬 Richiedi Assistenza
      </a>
    </div>
    <div class="footer-links">
      <a href="https://www.athlonroma.it" target="_blank">← Torna al sito principale</a>
      &nbsp;|&nbsp;
      <a href="https://www.athlonroma.it/regolamento" target="_blank">Termini e Condizioni</a>
      &nbsp;|&nbsp;
      <a href="https://www.athlonroma.it/privacy/" target="_blank">Privacy Policy</a>
    </div>
  </footer>

  <!-- Ready2Chat bot -->
  <script is:inline>
    (function() {
      var s = document.createElement('script');
      s.defer = true;
      s.id = '__carrierLoader__';
      s.src = 'https://ready2chat.tm.arch01.xyz/carrier/loader.js?t=2026-04-22T09:14:40.954+00:00';
      s.setAttribute('data-bot-identifier', 'athlon-helpbot-690c80264fdcdf44c1d999bf');
      s.onload = function() {
        // Collega il pulsante al widget dopo il caricamento
        var btn = document.getElementById('btn-open-chat');
        if (btn) {
          btn.addEventListener('click', function() {
            // Prova i metodi comuni delle chat widget
            if (window.Carrier && window.Carrier.open) { window.Carrier.open(); }
            else if (window.ready2chat && window.ready2chat.open) { window.ready2chat.open(); }
            else {
              // Simula click sull'elemento del widget nel DOM
              var widget = document.querySelector('[data-carrier-widget], .carrier-widget-button, #carrier-widget-button, [class*="carrier"], [id*="carrier"]');
              if (widget) { widget.click(); }
            }
          });
        }
      };
      document.body.appendChild(s);
    })();
  </script>

</body>
</html>
