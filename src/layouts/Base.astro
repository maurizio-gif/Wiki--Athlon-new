---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const { title = 'Athlon Wiki', description = 'Procedure e FAQ Athlon su abbonamenti, corsi, portale/app, prenotazioni e regole del club.' } = Astro.props;

const TYPEFORM_ID = '01J2ZQSSR25MNQ3VPCN60SMDBX';
---
<!DOCTYPE html>
<html lang="it">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content={description} />
  <title>{title} – Athlon Wiki</title>
  <link rel="icon" type="image/png" href="/favicon.png" />
  <script>
    (function() {
      const hash = window.location.hash;
      if (hash && (hash.includes('invite_token=') || hash.includes('recovery_token=') || hash.includes('confirmation_token='))) {
        window.location.href = '/admin/' + hash;
      }
    })();
  </script>
  <script is:inline src="//embed.typeform.com/next/embed.js"></script>
</head>
<body>

  <header class="site-header">
    <a href="/" class="header-logo">
      <img src="/logo.png" alt="Athlon Club" />
      <span class="logo-text">ATHLON <span>WIKI</span></span>
    </a>
    <div class="header-divider"></div>
    <div class="header-spacer"></div>
    <a href="https://www.athlonroma.it/regolamento" target="_blank" rel="noopener" class="btn-tc">
      Termini e Condizioni
    </a>
    <button
      class="btn-assistenza-header"
      data-tf-popup={TYPEFORM_ID}
      data-tf-opacity="100"
      data-tf-iframe-props="title=Richiedi Assistenza"
      data-tf-transitive-search-params
      data-tf-medium="snippet"
    >
      💬 Assistenza
    </button>
  </header>

  <!-- FLOATING BUTTON laterale -->
  <div class="tf-floating-wrap">
    <button
      class="tf-floating-btn"
      data-tf-popup={TYPEFORM_ID}
      data-tf-opacity="100"
      data-tf-iframe-props="title=Richiedi Assistenza"
      data-tf-transitive-search-params
      data-tf-medium="snippet"
    >
      <span class="tf-floating-icon">💬</span>
      <span class="tf-floating-label">RICHIEDI<br/>ASSISTENZA</span>
    </button>
  </div>

  <slot />

  <footer class="site-footer">
    <div class="footer-top">
      <div class="footer-info">
        <strong>Point 2000 Srl – Società Sportiva Dilettantistica</strong><br/>
        Via Ugo Ojetti 134, 00137 Roma &nbsp;|&nbsp;
        P.IVA IT05154811003 &nbsp;|&nbsp;
        <a href="mailto:desk@athlonroma.it">desk@athlonroma.it</a><br/>
        Affiliazione ASI: LAZ-RM4453 &nbsp;|&nbsp; FIN: 996434 &nbsp;|&nbsp; CSEN: 71519
      </div>
      <button
        class="btn-assistenza-footer"
        data-tf-popup={TYPEFORM_ID}
        data-tf-opacity="100"
        data-tf-iframe-props="title=Richiedi Assistenza"
        data-tf-transitive-search-params
        data-tf-medium="snippet"
      >
        💬 Richiedi Assistenza
      </button>
    </div>
    <div class="footer-links">
      <a href="https://www.athlonroma.it" target="_blank">← Torna al sito principale</a>
      &nbsp;|&nbsp;
      <a href="https://www.athlonroma.it/regolamento" target="_blank">Termini e Condizioni</a>
      &nbsp;|&nbsp;
      <a href="https://www.athlonroma.it/privacy/" target="_blank">Privacy Policy</a>
    </div>
  </footer>

</body>
</html>
